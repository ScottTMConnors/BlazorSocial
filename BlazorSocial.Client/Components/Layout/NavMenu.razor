@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular
@inject NavigationManager Nav

<header class="top-nav">
    <div class="top-nav-inner">
        @* Left: Brand / Home *@
        <a href="/" class="top-nav-brand">
            <FluentIcon Value="@(new Size24.ChatMultiple())" Color="Color.Custom" CustomColor="#FF4500"/>
            <span class="brand-text">BlazorSocial</span>
        </a>

        @* Center: Search bar *@
        <div class="top-nav-search">
            <FluentTextInput @bind-Value="_searchText" TextInputType="TextInputType.Search" Placeholder="Search BlazorSocial" autocomplete="off" name="nav-search"/>
        </div>

        @* Right: Navigation actions *@
        <nav class="top-nav-actions">
            <FluentButton Appearance="ButtonAppearance.Subtle"
                          IconStart="@(new Size20.Add())"
                          OnClick="@(() => Nav.NavigateTo($"/{NavigationRoute.CreatePost}"))"
                          title="Create Post">
                <span class="nav-btn-label">Create</span>
            </FluentButton>

            <FluentButton Appearance="ButtonAppearance.Subtle"
                          IconStart="@(new Size20.Shield())"
                          OnClick="@(() => Nav.NavigateTo($"/{NavigationRoute.Admin}"))"
                          title="Admin">
                <span class="nav-btn-label">Admin</span>
            </FluentButton>

            @if (IsAuthenticated)
            {
                <FluentButton Appearance="ButtonAppearance.Subtle"
                              IconStart="@(new Size20.Person())"
                              OnClick="@(() => Nav.NavigateTo($"/{NavigationRoute.Account.Manage.Index}"))"
                              title="@UserName">
                    <span class="nav-btn-label">@UserName</span>
                </FluentButton>
                <FluentButton Appearance="ButtonAppearance.Subtle"
                              IconStart="@(new Size20.ArrowExit())"
                              OnClick="@(() => Nav.NavigateTo($"/{NavigationRoute.Logout}", forceLoad: true, replace: true))"
                              title="Log Out">
                    <span class="nav-btn-label">Log Out</span>
                </FluentButton>
            }
            else
            {
                <FluentButton Appearance="ButtonAppearance.Primary"
                              Style="border-radius: 9999px; min-width: 80px;"
                              OnClick="@(() => _loginDialog?.ShowAsync())">
                    Log In
                </FluentButton>
            }
        </nav>
    </div>
</header>

<LoginDialog @ref="_loginDialog"/>

@code {

    [Parameter] public string? UserName { get; set; }

    [Parameter] public bool IsAuthenticated { get; set; }

    private string? _searchText;
    private LoginDialog? _loginDialog;

}