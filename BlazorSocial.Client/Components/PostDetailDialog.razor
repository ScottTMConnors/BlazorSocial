@implements IDialogContentComponent<string>

<FluentDialogHeader ShowDismiss="true">
    <FluentLabel Typo="Typography.PaneHeader">Post Details</FluentLabel>
</FluentDialogHeader>
<FluentDialogBody>
    <PostDetailContent PostId="@Content" />
</FluentDialogBody>

@code {

    [Parameter]
    public string Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

}
