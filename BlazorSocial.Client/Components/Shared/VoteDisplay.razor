@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular
@using FilledIcons = Microsoft.FluentUI.AspNetCore.Components.Icons.Filled

<div class="post-card-actions">
    <div class="post-action-pill glass-pill @(CurrentUserVote == 1 ? "glow-up" : CurrentUserVote == -1 ? "glow-down" : "")">
        <span class="vote-btn vote-up @(CurrentUserVote == 1 ? "voted" : "")" @onclick="() => VotePost(true)" @onclick:stopPropagation @onclick:preventDefault>
            @if (CurrentUserVote == 1)
            {
                <FluentIcon Value="@(new FilledIcons.Size20.ArrowOutlineUpRight())"/>
            }
            else
            {
                <FluentIcon Value="@(new Size20.ArrowOutlineUpRight())"/>
            }
        </span>
        <span class="post-action-count">@Score</span>
        <span class="vote-btn vote-down @(CurrentUserVote == -1 ? "voted" : "")" @onclick="() => VotePost(false)" @onclick:stopPropagation @onclick:preventDefault>
            @if (CurrentUserVote == -1)
            {
                <FluentIcon Value="@(new FilledIcons.Size20.ArrowOutlineDownLeft())"/>
            }
            else
            {
                <FluentIcon Value="@(new Size20.ArrowOutlineDownLeft())"/>
            }
        </span>
    </div>
</div>

@code {

    [Parameter] [EditorRequired] public int CurrentUserVote { get; set; }
    [Parameter] [EditorRequired] public EventCallback<int> CurrentUserVoteChanged { get; set; }

    [Parameter] [EditorRequired] public int Score { get; set; }
    [Parameter] [EditorRequired] public EventCallback<int> ScoreChanged { get; set; }

    [Parameter] public EventCallback<bool> OnVote { get; set; }

    private async Task VotePost(bool isUpvote)
    {
        if (isUpvote)
        {
            if (CurrentUserVote == 1)
            {
                // Remove upvote
                Score -= 1;
                CurrentUserVote = 0;
            }
            else
            {
                Score += 1;
                CurrentUserVote = 1;
            }
        }
        else
        {
            if (CurrentUserVote == -1)
            {
                // Remove downvote
                Score += 1;
                CurrentUserVote = 0;
            }
            else
            {
                Score -= 1;
                CurrentUserVote = -1;
            }
        }

        await CurrentUserVoteChanged.InvokeAsync(CurrentUserVote);
        await ScoreChanged.InvokeAsync(Score);
        await OnVote.InvokeAsync(isUpvote);
    }

}