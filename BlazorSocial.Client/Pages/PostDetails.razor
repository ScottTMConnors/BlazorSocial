@attribute [Route($"/{NavigationRoute.PostDetailsTemplate}")]

@rendermode @(new InteractiveWebAssemblyRenderMode(false))

@inject NavigationManager NavigationManager

@if (_isValid)
{
    <PostDetailContent PostId="@PostId"/>
}

@code {

    [Parameter] public string IdParam { get; set; } = "";

    private bool _isValid;

    private PostId PostId { get; set; } = PostId.Empty;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(IdParam) || !PostId.TryParse(IdParam, out var postId))
        {
            NavigationManager.NavigateTo($"/{NavigationRoute.ViewPosts}");
            return;
        }

        PostId = postId;

        _isValid = true;
    }

}