@page "/"
@page "/ViewPosts"

@rendermode @(new InteractiveWebAssemblyRenderMode(false))
@using System.Collections.Frozen
@using BlazorSocial.Client.Components.Shared
@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular
@implements IAsyncDisposable

@inject HttpClient Http
@inject IJSRuntime JS
@inject IDialogService DialogService

<svg style="position:absolute;width:0;height:0;" aria-hidden="true">
    <defs>
        <linearGradient id="upvote-gradient" x1="0" y1="1" x2="0" y2="0">
            <stop offset="0%" stop-color="#FF4500"/>
            <stop offset="100%" stop-color="#DC1E00"/>
        </linearGradient>
        <linearGradient id="downvote-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#5C6BC0"/>
            <stop offset="100%" stop-color="#6E14AA"/>
        </linearGradient>
    </defs>
</svg>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="10px" style="max-width:1000px; margin:0 auto 0 auto; height:auto;">
    @foreach (var post in _posts)
    {
        <a href="@($"/PostDetails/{post.PostId:N}")" data-enhance-nav="false" @onclick="@(e => HandleCardClick(e, post.PostId))" @onclick:preventDefault class="post-card-link">
            <FluentCard style="width:100%;max-height:350px;padding:16px;overflow:hidden;">
                <div style="display:flex; align-items:baseline; gap:6px; font-size:12px;">
                    <span style="font-weight:700;">@post.AuthorName</span>
                    <span style="color:var(--neutral-foreground-hint);">•</span>
                    <span style="color:var(--neutral-foreground-hint);">@ConvertDateToString(post.PostDate)</span>
                </div>
                <div class="post-card-title">
                    <FluentLabel Size="LabelSize.Large">@post.Title</FluentLabel>
                </div>
                <div class="post-card-content">
                    @((MarkupString)post.Content)
                </div>
                <div class="post-card-actions">
                    <VoteDisplay CurrentUserVote="@post.CurrentUserVote" Score="@post.Score" PostId="@post.PostId"/>
                    <div class="post-action-pill glass-pill">
                        <FluentIcon Value="@(new Size20.Comment())" Color="@Color.Default"/>
                        <span class="post-action-count">@post.CommentCount</span>
                    </div>
                </div>
            </FluentCard>
        </a>
        <FluentDivider style="width: 100%;"/>
    }
    @if (!_allLoaded)
    {
        <div @ref="_sentinelRef" style="height:1px;"></div>
        <LoadingSpinner/>
    }
</FluentStack>

@code {

    private const int PageSize = 10;
    private readonly List<ViewPostDto> _posts = [];
    private ElementReference _sentinelRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ViewPosts>? _selfRef;
    private bool _loading;
    private bool _allLoaded;
    private bool Disposed => _cts.IsCancellationRequested;

    private readonly CancellationTokenSource _cts = new();
    private CancellationToken CancellationToken => _cts.Token;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadMorePosts();
            if (Disposed) return;
            StateHasChanged();

            await using var jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", CancellationToken, "./js/ViewPosts.js");
            _module = await jsModule.InvokeAsync<IJSObjectReference>(
                "createScrollObserver", CancellationToken);
            _selfRef = DotNetObjectReference.Create(this);
        }

        if (!_allLoaded && _module is not null)
        {
            await _module.InvokeVoidAsync("observe", CancellationToken, _sentinelRef, _selfRef);
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (Disposed || _loading || _allLoaded) return;
        await LoadMorePosts();
        if (Disposed) return;
        StateHasChanged();

        if (!_allLoaded && _module is not null)
        {
            await _module.InvokeVoidAsync("observe", CancellationToken, _sentinelRef, _selfRef);
        }
    }

    private async Task LoadMorePosts()
    {
        _loading = true;
        try
        {
            var newPosts = await Http.GetFromJsonAsync<List<ViewPostDto>>(
                $"api/posts?startIndex={_posts.Count}&count={PageSize}", CancellationToken) ?? [];

            _posts.AddRange(newPosts);

            if (newPosts.Count < PageSize)
            {
                _allLoaded = true;
            }
        }
        catch
        {
            // Swallow – the user can retry by scrolling again
        }
        finally
        {
            _loading = false;
        }
    }

    public static string ConvertDateToString(DateTime? date)
    {
        if (!date.HasValue)
            return "Invalid date";

        var diff = DateTime.Now - date.Value;

        return diff.TotalDays switch
        {
            >= 365 => $"{(int)(diff.TotalDays / 365)} yr. ago",
            >= 30 => $"{(int)(diff.TotalDays / 30)} mo. ago",
            >= 2 => $"{(int)diff.TotalDays} days ago",
            >= 1 => "1 day ago",
            _ when diff.TotalHours >= 1 => $"{(int)diff.TotalHours} hr. ago",
            _ when diff.TotalMinutes >= 1 => $"{(int)diff.TotalMinutes} min ago",
            _ => "just now"
        };
    }

    private async Task HandleCardClick(MouseEventArgs e, Guid postId)
    {
        if (e.CtrlKey || e.MetaKey || e.ShiftKey)
        {
            await JS.InvokeVoidAsync("open", CancellationToken, $"/PostDetails/{postId:N}", "_blank");
            return;
        }

        await DialogService.ShowDialogAsync<PostDetailDialog>(options =>
        {
            options.Width = "min(1500px, 95vw)";
            options.Height = "fit-content";
            options.Modal = false;
            options.Parameters = new Dictionary<string, object?>
            {
                { nameof(PostDetailDialog.PostId), postId.ToString("N") }
            }.ToFrozenDictionary();
        });
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();

        try
        {
            if (_module is not null)
            {
                // ReSharper disable once MethodSupportsCancellation
                await _module.InvokeVoidAsync("disconnect");
                await _module.DisposeAsync();
                _module = null;
            }
        }
        catch (JSDisconnectedException)
        {
        }

        _selfRef?.Dispose();
        _selfRef = null;
        _cts.Dispose();
    }

}