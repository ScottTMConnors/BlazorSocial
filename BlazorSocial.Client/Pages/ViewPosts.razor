@page "/"
@page "/ViewPosts"

@rendermode @(new InteractiveWebAssemblyRenderMode(false))

@implements IAsyncDisposable

@inject HttpClient Http
@inject IJSRuntime JS
@inject IDialogService DialogService

<FluentStack Orientation="Orientation.Vertical" VerticalGap="10" style="max-width:1000px; margin:0 auto 0 auto;">
    @foreach (var post in _posts)
    {
        <a href="@($"/PostDetails/{post.PostId:N}")" data-enhance-nav="false" @onclick="@(e => HandleCardClick(e, post.PostId))" @onclick:preventDefault class="post-card-link">
            <FluentCard AreaRestricted="true" style="width:100%;max-height:350px;padding:16px;overflow:hidden;">
                <FluentLabel Typo="Typography.Body">@post.AuthorName</FluentLabel>
                <div class="post-card-title">
                    <FluentLabel Typo="Typography.H3">@post.Title</FluentLabel>
                </div>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@ConvertDateToString(post.PostDate)</FluentLabel>
                <FluentDivider Role="@DividerRole.Separator"/>
                <div class="post-card-content">
                    @((MarkupString)post.Content)
                </div>
            </FluentCard>
        </a>
        <FluentDivider Role="@DividerRole.Separator" style="width: 100%;"/>
    }
    @if (!_allLoaded)
    {
        <div @ref="_sentinelRef" style="height:1px;"></div>
        <FluentProgressRing style="margin: 10px auto;"/>
    }
</FluentStack>

@code {

    private const int PageSize = 10;
    private readonly List<ViewPostDto> _posts = [];
    private ElementReference _sentinelRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ViewPosts>? _selfRef;
    private bool _loading;
    private bool _allLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadMorePosts();
            StateHasChanged();

            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/ViewPosts.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("observe", _sentinelRef, _selfRef);
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (_loading || _allLoaded) return;
        await LoadMorePosts();
        StateHasChanged();

        if (!_allLoaded && _module is not null)
        {
            await _module.InvokeVoidAsync("observe", _sentinelRef, _selfRef);
        }
    }

    private async Task LoadMorePosts()
    {
        _loading = true;
        try
        {
            var newPosts = await Http.GetFromJsonAsync<List<ViewPostDto>>(
                $"api/posts?startIndex={_posts.Count}&count={PageSize}") ?? [];

            _posts.AddRange(newPosts);

            if (newPosts.Count < PageSize)
            {
                _allLoaded = true;
            }
        }
        catch
        {
            // Swallow – the user can retry by scrolling again
        }
        finally
        {
            _loading = false;
        }
    }

    public static string ConvertDateToString(DateTime? date)
    {
        if (!date.HasValue)
        {
            return "Invalid date";
        }

        var difference = DateTime.Now - date.Value;

        if (difference.TotalDays >= 1)
        {
            return date.Value.ToString();
        }

        if (difference.TotalHours >= 1)
        {
            return $"{(int)difference.TotalHours}h";
        }

        if (difference.TotalMinutes >= 1)
        {
            return $"{(int)difference.TotalMinutes}m";
        }

        return $"{(int)difference.TotalSeconds}s";
    }

    private async Task HandleCardClick(MouseEventArgs e, Guid postId)
    {
        if (e.CtrlKey || e.MetaKey || e.ShiftKey)
        {
            await JS.InvokeVoidAsync("open", $"/PostDetails/{postId:N}", "_blank");
            return;
        }

        await DialogService.ShowDialogAsync<PostDetailDialog>(postId.ToString("N"), new DialogParameters
        {
            Title = "Post Details",
            Width = "min(1200px, 90vw)",
            Height = "fit-content",
            PreventDismissOnOverlayClick = false,
            PreventScroll = true,
            ShowDismiss = true,
            PrimaryAction = null,
            SecondaryAction = null
        });
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("disconnect");
            await _module.DisposeAsync();
        }

        _selfRef?.Dispose();
    }

}