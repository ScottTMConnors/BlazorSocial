@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            <div class="page-loading">
                <FluentProgressRing style="margin: 10px auto;"/>
            </div>
            @Body
        </article>
    </main>
</div>

<FluentDialogProvider @rendermode="@(new InteractiveWebAssemblyRenderMode(false))"/>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code{

    protected override async Task OnInitializedAsync()
    {
        // MainLayout runs on the server (SSR). WASM page content renders
        // inside @Body after the WebAssembly runtime loads.
    }

}